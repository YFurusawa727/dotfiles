#!/bin/sh

set -e

USERNAME=$(whoami)
HOMEBREW_INSTALL_URL="https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh"

### Function
log() {
    message="$1"
    echo "📌 $message"
}

error_exit() {
    message="$1"
    echo "❌ Error: $message" >&2
    exit 1
}

verify_command() {
    command="$1"
    if ! command -v "$command" >/dev/null 2>&1; then
        error_exit "$command is not installed or not in PATH"
    fi
}

# Verify Homebrew installation
if [ ! -f /opt/homebrew/bin/brew ]; then
    log "Installing Homebrew..."
    if ! /bin/bash -c "$(curl -fsSL $HOMEBREW_INSTALL_URL)"; then
        error_exit "Failed to install Homebrew"
    fi
    (echo; echo 'eval "$(/opt/homebrew/bin/brew shellenv)"') >> "/Users/$USERNAME/.zprofile"
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

verify_command brew

if [ ! -d ~/dotfiles ]; then
    log "Cloning dotfiles repository..."
    cd ~ || error_exit "Failed to change to home directory"
    if ! git clone https://github.com/YFurusawa727/dotfiles.git; then
        error_exit "Failed to clone dotfiles repository"
    fi
fi

log "Installing Homebrew packages..."
if ! brew bundle -v --file=~/dotfiles/Brewfile; then
    error_exit "Failed to install Homebrew packages"
fi

# Setup environment variables for git configuration
log "Setting up environment variables..."
if [ ! -f ~/dotfiles/.env ]; then
    log "Creating .env file for personal configuration..."
    cp ~/dotfiles/.env.example ~/dotfiles/.env
    
    echo ""
    echo "📝 Please configure your personal information:"
    echo "   Edit ~/dotfiles/.env and set your name and email"
    echo ""
    echo "   Current default values:"
    cat ~/dotfiles/.env | grep -E "^GIT_"
    echo ""
    
    # Interactive setup option
    read -p "Would you like to set your git configuration now? (y/n): " setup_git
    if [ "$setup_git" = "y" ] || [ "$setup_git" = "Y" ]; then
        read -p "Enter your full name: " git_name
        read -p "Enter your email: " git_email
        
        if [ -n "$git_name" ] && [ -n "$git_email" ]; then
            # Use a safer method to update .env file without sed vulnerabilities
            {
                echo "# Environment variables for dotfiles configuration"
                echo "# Copy this file to .env and set your personal values"
                echo ""
                echo "# Git configuration"
                echo "# These variables are used in .gitconfig to avoid exposing personal information in the repository"
                printf 'GIT_USER_NAME="%s"\n' "$git_name"
                printf 'GIT_USER_EMAIL="%s"\n' "$git_email"
                echo ""
                echo "# Optional: Custom shell configuration"
                echo "# SHELL_THEME=\"custom\""
                echo ""
                echo "# Optional: Development environment settings  "
                echo "# NODE_VERSION=\"22.18.0\""
                echo "# PYTHON_VERSION=\"3.12.3\""
                echo "# FIREBASE_VERSION=\"14.12.1\""
            } > ~/dotfiles/.env
            log "✓ Git configuration updated in .env file"
        fi
    fi
    
    # Load environment variables safely
    if [ -f ~/dotfiles/.env ]; then
        log "Loading environment variables..."
        set -a
        . ~/dotfiles/.env
        set +a
    fi
else
    log "✓ .env file already exists"
    # Load existing environment variables safely
    set -a
    . ~/dotfiles/.env
    set +a
fi

if [ ! -d ~/.config ]; then
    log "Creating ~/.config directory..."
    mkdir -p ~/.config/
fi

log "Setting up configuration files with stow..."
log "Adopting existing configuration files if they exist..."
if ! stow --adopt -v -d ~/dotfiles/packages -t ~ git asdf zsh bash starship alacritty; then
    error_exit "Failed to setup configuration files with stow"
fi

# Set up git configuration from template
if [ ! -f ~/dotfiles/packages/git/.gitconfig ]; then
    log "Creating .gitconfig from template..."
    cp ~/dotfiles/packages/git/.gitconfig.example ~/dotfiles/packages/git/.gitconfig
    
    # Replace placeholders with actual values if environment variables are set
    if [ -n "$GIT_USER_NAME" ] && [ -n "$GIT_USER_EMAIL" ]; then
        log "Setting up git configuration with environment variables..."
        sed -i '' "s/Your Full Name/$GIT_USER_NAME/" ~/dotfiles/packages/git/.gitconfig
        sed -i '' "s/your.email@example.com/$GIT_USER_EMAIL/" ~/dotfiles/packages/git/.gitconfig
        log "Git user configured: $GIT_USER_NAME <$GIT_USER_EMAIL>"
    else
        log "Git configuration created with default template"
        log "Please edit ~/dotfiles/packages/git/.gitconfig to set your name and email"
    fi
else
    log "✓ Git configuration already exists"
fi

# Show what files were adopted
if [ -d ~/.git ] || [ -f ~/.gitconfig ] || [ -f ~/.zshrc ] || [ -f ~/.bashrc ]; then
    log "Notice: Existing configuration files have been adopted into dotfiles"
    log "Your original settings are now managed by dotfiles and preserved"
    log "You can review and customize them in ~/dotfiles/packages/"
fi

is_dir () {
    path="$1"
    [ -d "$path" ]
}

is_runtime_versions_changed () {
    plugin="$1"
    specified=$(grep "$plugin" ~/.tool-versions | awk '{$1=""; print $0}')
    installed=$(asdf list "$plugin" 2>&1)

    is_changed=
    for version in $specified; do
        match=$(echo "$installed" | grep "$version")
        [ -z "$match" ] && is_changed=1
    done

    [ "$is_changed" ]
}


### asdf Install Script
log "Setting up asdf plugins and runtimes..."
verify_command asdf

if [ -f ~/.tool-versions ]; then
    for plugin in $(awk '{print $1}' ~/.tool-versions); do
        if ! is_dir ~/.asdf/plugins/"$plugin"; then
            log "Adding asdf plugin: $plugin"
            if ! asdf plugin add "$plugin"; then
                error_exit "Failed to add asdf plugin: $plugin"
            fi
        fi
    done

    for plugin in $(asdf plugin list); do
        if is_runtime_versions_changed "$plugin"; then
            log "Installing runtime: $plugin"
            if ! asdf install "$plugin"; then
                error_exit "Failed to install runtime: $plugin"
            fi
        fi
    done
else
    log "Warning: ~/.tool-versions not found, skipping asdf runtime installation"
fi

log "Dotfiles setup completed successfully! \ud83c\udf89"
