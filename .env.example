# Environment variables for dotfiles configuration
# Copy this file to .env and set your personal values

# Git configuration
# These variables are used in .gitconfig to avoid exposing personal information in the repository
GIT_USER_NAME="Your Full Name"
GIT_USER_EMAIL="your.email@example.com"

# Optional: Custom shell configuration
# SHELL_THEME="custom"

# Optional: Development environment settings
# NODE_VERSION="22.18.0"
# PYTHON_VERSION="3.12.3"
# FIREBASE_VERSION="14.12.1"
