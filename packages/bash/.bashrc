alias a='alias'
alias ..='cd ..'
alias ..2='cd ../..'
alias ..3='cd ../../..'
alias ll='clear && ls -alF'
alias g='git'
alias m='make'
alias s='ssh'
alias dotinstall='~/dotfiles/install'
alias dottest='~/dotfiles/test_install.sh 2>/dev/null | tail -5'
alias dottest-full='~/dotfiles/test_install.sh'
alias dottest-summary='~/dotfiles/test_install.sh 2>/dev/null | grep -E "(✓|✗|Tests completed)"'
alias dotvalidate='~/dotfiles/validate.sh'
alias dotcheck='~/dotfiles/validate.sh | tail -3'